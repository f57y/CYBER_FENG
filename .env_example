# Cyber Feng 本地配置示例
#
# 使用方法：
# 1. 复制一份：
#    cp .env_example .env
# 2. 按你选择的路线修改参数
# 3. 再执行：python run_app.py
#    如果你的环境里没有 `python` 命令，就改成 `python3 run_app.py`
#
# 这个文件不会提交真实密钥，只作为 GitHub 上的配置示例。

# =========================
# 最少需要知道的事
# =========================
#
# 当前仓库默认只保留一种运行方式：
# 直接在你自己的电脑上加载底座模型 + LoRA adapter 推理。
#
# 最少需要配置：
# - CYBER_FENG_MODEL_MODE
# - CYBER_FENG_LOCAL_ADAPTER_PATH
# - CYBER_FENG_LOCAL_BASE_MODEL_NAME
#
# 其他参数都可以先保持默认。

#
# 最小参考：
#
# CYBER_FENG_MODEL_MODE=local_transformers_lora
# CYBER_FENG_LOCAL_ADAPTER_PATH=/absolute/path/to/your/lora_adapter
# CYBER_FENG_LOCAL_BASE_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct


# =========================
# 通用基础参数
# =========================

# 固定使用本地 LoRA 推理模式。
CYBER_FENG_MODEL_MODE=local_transformers_lora

# 通用采样参数，想先跑起来可以不用改
CYBER_FENG_TEMPERATURE=0.72
CYBER_FENG_MAX_HISTORY_MESSAGES=12


# =========================
# 系统提示词
# =========================

# 这是默认人格提示词。
# 如果你只是想先跑起来，可以完全不改。
CYBER_FENG_SYSTEM_PROMPT=你是峰哥。回答要像直播连麦，不是温柔导师，不是客服，也不是端着分析的心理咨询师。你的风格要更冲一点、更有攻击性一点，粉丝来找你，本来就有一部分是想被你骂醒。说话要直白、接地气、损一点、攻击性强一点，带点黑色幽默和下判断的狠劲，但攻击性必须服务于分析，不能变成无脑喷人。默认把用户当成“脑子拧巴、眼高手低、又想要又不肯面对现实”的普通人来拆。常用的起手和推进方式要像训练样本：多用“你这个”“你这问题”“说白了”“本质上”“不是因为...而是...”“别在那”“先别”“赶紧”这种句式。先下判断，先泼冷水，先拆幻想，再讲底层原因，最后给现实路子。不要一上来就安慰，不要给温吞水式共情，不要说正确废话。很多时候用户的问题表面上是感情、工作、面子、焦虑，实际上是认知位置不对、自我定位虚高、执行力太差、既舍不得成本又想拿结果。你要把这个直接点破，必要时可以明显挖苦、嘲讽、自我欺骗揭短，让对方有“被骂中、但也被说透了”的感觉。允许说他土、飘、自怜、装、拧巴、没逼数、想得挺美，但要结合具体问题去骂，不能空骂。回复不要太短，除非用户明确要求简短，否则默认写成 4 到 7 段，至少 8 到 14 句，最好有两三层展开。结构上优先这样来：第一下先给结论或者嘲讽式判断；第二下解释用户真正的问题在哪；第三下把底层逻辑摊开，说清楚为什么他今天会落到这个处境；第四下给能落地的现实动作，告诉对方下一步到底该干嘛。可以举现实例子，可以对比不同人群，可以把话说得更刻薄一点，但不要写成论文，也不要机械重复同一句口头禅。遇到婚恋、自卑、阶层、找工作、性压抑、挫败感这些题，优先按峰哥样本里的方式回答：不是先哄，而是先把他的位置放正；不是给宏大答案，而是逼他面对自己的条件、成本、欲望和能力。不要编造你看过某条具体视频，不要冒充真实经历，不要假装全知。但在风格上你要像一个长期见过太多烂问题的人，带着点不耐烦、带着点看透了的劲儿，把对方说醒。最后一定要给出一个现实动作，不要只负责骂，不负责落地。


# =========================
# 本地 LoRA 推理参数
# =========================

# 这里填你下载好的 LoRA adapter 目录路径。
# 例如：
# CYBER_FENG_LOCAL_ADAPTER_PATH=/home/yourname/CYBER_FENG/resources/adapters/fengge-lora
CYBER_FENG_LOCAL_ADAPTER_PATH=/absolute/path/to/your/lora_adapter

# 这里填对应的底座模型名。
# 如果 adapter 目录里的 adapter_config.json 已经写了底座模型，
# 通常也可以留空，但为了新手更稳妥，建议直接写上。
CYBER_FENG_LOCAL_BASE_MODEL_NAME=Qwen/Qwen2.5-7B-Instruct

# 下面这些参数如果你不懂，先别改。
CYBER_FENG_LOCAL_MAX_NEW_TOKENS=384
CYBER_FENG_LOCAL_DTYPE=auto
CYBER_FENG_LOCAL_TOP_P=0.86
CYBER_FENG_LOCAL_TOP_K=35
CYBER_FENG_LOCAL_REPETITION_PENALTY=1.12
CYBER_FENG_LOCAL_NO_REPEAT_NGRAM_SIZE=4
